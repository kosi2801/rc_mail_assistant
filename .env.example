# =============================================================================
# Repair Cafe Mail Assistant — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- Required: Application ---
# Used for future session-signing and CSRF protection middleware.
SECRET_KEY=change_me_to_a_random_32_char_string

# --- Required: Database ---
POSTGRES_USER=rcmail
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=rcmail
# Full async DSN assembled by the app — override only if using external DB
# DATABASE_URL=postgresql+asyncpg://rcmail:password@postgres:5432/rcmail

# --- Optional: LLM Runtime (Ollama) ---
# Omit or leave empty to start in degraded mode (AI features disabled).
OLLAMA_BASE_URL=http://ollama:11434

# --- Optional: Gmail OAuth Credentials ---
# Create a Google Cloud project and an OAuth 2.0 Client ID (Web application type).
# Set GMAIL_CLIENT_ID and GMAIL_CLIENT_SECRET here, then use the in-app
# "Connect Gmail" button on the Configuration page to authorize and store the
# refresh token securely in the database.
# Do NOT set GMAIL_REFRESH_TOKEN here — the in-app OAuth flow manages it automatically.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# --- Optional: Startup Retry Tuning ---
# How many times to retry the DB connection before exiting.
DB_CONNECT_ATTEMPTS=5
# Seconds between retry attempts (uses exponential backoff up to 10s).
DB_CONNECT_DELAY_SECONDS=2
